# Headless WordPress CMS
# Set WORDPRESS_URL to your WordPress install's public URL.
# When unset, the site falls back to the static TypeScript data files.
WORDPRESS_URL=https://cms.your-mission-domain.gov.ng

# Optional: Bearer token for a protected WPGraphQL endpoint.
WORDPRESS_API_KEY=

# On-demand ISR revalidation secret (must match the WordPress webhook payload).
NEXT_REVALIDATE_SECRET=change-me-to-a-strong-random-string

# Cache TTL in seconds for WordPress content (default: 60).
NEXT_REVALIDATE_TTL=60
